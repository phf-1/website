  doi          = {10.1016/0304-3975(77)90044-5},
  url          = {https://homepages.inf.ed.ac.uk/gdp/publications/LCF.pdf},
  note         = {Seminal paper introducing PCF and showing that parallel constructs like parallel conditional (pc) and parallel-or (por) cannot be programmed in the deterministic language. The key argument uses the Activity Lemma (Lemma 4.2) to establish the sequential nature of reduction, proving that non-sequential parallel evaluation violates the deterministic operational semantics (see especially pages 236--238 and the discussion of parallel features). This is the original and most cited source for the undefinability of parallel-or in PCF/lambda-calculus-based languages.}
}

